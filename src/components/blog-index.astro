---
type BlogIndexItem = {
  slug: string;
  title: string;
  author: {
    fullname: string;
    avatar?: string | null;
  } | null;
};

const { posts } = Astro.props as { posts: BlogIndexItem[] };
---

<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
  <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => (
      <li class="group">
        <a
          href={`/blog/${post.slug}`}
          class="flex h-full flex-col overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition duration-300 hover:-translate-y-1 hover:border-slate-300 hover:shadow-xl"
        >
          <div class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-700 px-6 py-8">
            <h2 class="mt-6 text-2xl font-semibold leading-tight tracking-tight text-white transition group-hover:text-amber-200">
              {post.title}
            </h2>
          </div>

          <div class="flex flex-1 flex-col justify-between gap-6 p-6">
            <div class="flex items-center gap-3">
              <div class="flex h-12 w-12 items-center justify-center overflow-hidden rounded-full bg-slate-100 ring-1 ring-slate-200">
                {post.author?.avatar ? (
                  <img
                    src={post.author.avatar}
                    alt={post.author.fullname}
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <span class="text-sm font-semibold text-slate-500">
                    {post.author?.fullname?.charAt(0) ?? "A"}
                  </span>
                )}
              </div>

              <div>
                <p class="text-sm font-medium text-slate-900">
                  {post.author?.fullname ?? "Unknown author"}
                </p>
              </div>
            </div>
          </div>
        </a>
      </li>
    ))}
  </ul>
</section>
